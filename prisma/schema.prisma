generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PaymentCurrency {
  TON
  PLANKTON
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  EXPIRED
}

enum SubscriptionPlan {
  ONE_MONTH
  THREE_MONTHS
  TWELVE_MONTHS
}

model User {
  id         String  @id @default(cuid())
  wallet     String  @unique
  telegramId String? @unique
  refCode    String? @unique
  language   String?
  referrerId       String?
  referredAt       DateTime?
  bonusYearGranted Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  devices       VpnDevice[]
  payments      Payment[]
  subscriptions Subscription[]
  referrer          User?                @relation("UserReferrals", fields: [referrerId], references: [id], onDelete: SetNull)
  referrals         User[]               @relation("UserReferrals")
  earningsReceived  ReferralEarning[]    @relation("EarningRecipient")
  earningsTriggered ReferralEarning[]    @relation("EarningSource")
  withdrawals       ReferralWithdrawal[]
}

model ReferralEarning {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation("EarningRecipient", fields: [userId], references: [id], onDelete: Cascade)
  referralId String
  referral   User     @relation("EarningSource", fields: [referralId], references: [id], onDelete: Cascade)
  paymentId  String   @unique
  amountTon  Decimal  @db.Decimal(20, 9)
  status     String   @default("available")
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([referralId])
}

model ReferralWithdrawal {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  amountTon   Decimal   @db.Decimal(20, 9)
  walletAddr  String
  status      String    @default("pending")
  txHash      String?
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  @@index([userId])
  @@index([status])
}

model VpnDevice {
  id String @id @default(cuid())

  wallet String
  name   String

  clientId String?
  address  String?
  protocol String  @default("wireguard")

  enabled   Boolean   @default(true)
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [wallet], references: [wallet], onDelete: Cascade)

  @@unique([wallet, name])
}

model Payment {
  id String @id @default(cuid())

  wallet String

  plan     SubscriptionPlan
  currency PaymentCurrency

  status PaymentStatus @default(PENDING)

  amountUsd   Float
  amountToken String

  txHash String? @unique

  paidAt    DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [wallet], references: [wallet], onDelete: Cascade)

  subscription Subscription?
}

model Subscription {
  id String @id @default(cuid())

  wallet String

  plan     SubscriptionPlan
  currency PaymentCurrency

  active Boolean @default(true)

  startedAt DateTime @default(now())
  expiresAt DateTime

  paymentId String? @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  payment Payment? @relation(fields: [paymentId], references: [id])

  user User @relation(fields: [wallet], references: [wallet], onDelete: Cascade)
}
